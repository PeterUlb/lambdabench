# Build context excludes for the benchmark-runner image (deploy/Dockerfile,
# built with context = repo root). The container rebuilds every artifact from
# source, so none of the generated output or caches below are needed - shipping
# them would bloat the context (tens of GB) and bake stale output into the image.
# This mirrors .gitignore's source-vs-output split.

# Rust build caches (root workspace + per-opt-level + the standalone smithy crates)
**/target
**/target-o3*
**/target-oz*

# Node / JS dependencies and generated bundles
**/node_modules
scenarios/node/**/dist
scenarios/node/.ssdk

# Python staging
scenarios/python/.build
__pycache__/
*.pyc

# Gradle build output + caches
**/build
**/.gradle
scenarios/**/bin/

# Built Lambda zips (regenerated by `bencher build`)
/dist

# Benchmark results and scratch (regenerated by a run; not a build input)
/results
/.tmp

# Observable site build output + loader cache
site/out-site
**/.observablehq/cache

# CDK app: deps and synth output (not needed inside the runner image)
deploy/cdk/node_modules
deploy/cdk/cdk.out
deploy/cdk/cdk.context.json

# Version control, editor, and OS cruft
.git
.gitignore
**/.DS_Store
.claude

# Generated crypto fixtures (regenerated by the harness)
bencher/fixtures/authz_signing_key.pem
bencher/fixtures/authz_public_jwk.json
bencher/fixtures/authz_token.txt
scenarios/go/authz/authz_public_jwk.json
